# ──────────────────────────────────────────────────────────────────────────────
# Aurora QA — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key (required for all agent operations)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Model Configuration ─────────────────────────────────────────────────────

# AI model to use for agent reasoning (default: claude-opus-4-6)
# Options: claude-opus-4-6, claude-sonnet-4-20250514, claude-haiku-35-20241022, etc.
AURORA_MODEL=claude-opus-4-6

# Maximum tokens per API response (default: 8192)
AURORA_MAX_TOKENS=8192

# Sampling temperature for model responses (default: 0.2, range: 0-1)
# Lower = more deterministic, higher = more creative
AURORA_TEMPERATURE=0.2

# ─── Dashboard ────────────────────────────────────────────────────────────────

# Port for the Next.js dashboard (default: 3001)
DASHBOARD_PORT=3001

# Host binding for the dashboard (default: 0.0.0.0)
DASHBOARD_HOST=0.0.0.0

# Allowed CORS origins for the dashboard API (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Memory & Knowledge Base ─────────────────────────────────────────────────

# Maximum entries in the knowledge base (default: 50000)
MEMORY_MAX_ENTRIES=50000

# Cosine similarity threshold for knowledge base queries (default: 0.72)
MEMORY_SIMILARITY_THRESHOLD=0.72

# File path for persisting the knowledge base (optional, in-memory if unset)
MEMORY_PERSIST_PATH=./data/knowledge.json

# ─── Logging ──────────────────────────────────────────────────────────────────

# Log level (default: info)
# Options: debug, info, warn, error
LOG_LEVEL=info

# Log format (default: pretty)
# Options: json, pretty
LOG_FORMAT=pretty

# ─── MCP Server ───────────────────────────────────────────────────────────────

# MCP server name reported to clients (default: aurora-qa)
AURORA_MCP_NAME=aurora-qa

# MCP server version reported to clients (default: 1.0.0)
AURORA_MCP_VERSION=1.0.0

# ─── CI/CD Adapters ──────────────────────────────────────────────────────────

# GitHub token for CI/CD integration (optional)
# GITHUB_TOKEN=ghp_your-token-here

# GitLab token for CI/CD integration (optional)
# GITLAB_TOKEN=glpat-your-token-here
