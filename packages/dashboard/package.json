{
  "name": "@aurora-qa/dashboard",
  "version": "1.0.0",
  "description": "Aurora QA dashboard — REST API and real-time WebSocket server",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@aurora-qa/core": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
